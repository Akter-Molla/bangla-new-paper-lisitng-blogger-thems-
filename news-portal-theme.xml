                    <b:includable id='main'>
                        <div class='category-section'>
                            <div class='cat-header'><i class='fas fa-landmark'/><h2><data:title/></h2></div>
                            <div class='news-grid'>
                                <b:loop values='data:links' var='link'>
                                    <div class='news-card' expr:onclick='&quot;viewNews(\&quot;&quot; + data:link.target + &quot;\&quot;, \&quot;&quot; + data:link.name + &quot;\&quot;)&quot;'>
                                        <img expr:src='&quot;https://www.google.com/s2/favicons?sz=80&amp;domain=&quot; + data:link.target'/>
                                        <span><data:link.name/></span>
                                        <small>দৈনিক সংবাদপত্র</small>
                                    </div>
                                </b:loop>
                            </div>
                        </div>
                    </b:includable>
                </b:widget>
            </b:section>

