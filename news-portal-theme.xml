                        <b:widget-setting name='link-0'>https://www.prothomalo.com/</b:widget-setting>
                        <b:widget-setting name='text-1'>Ittefaq</b:widget-setting>
                        <b:widget-setting name='link-1'>https://www.ittefaq.com.bd/</b:widget-setting>
                        <b:widget-setting name='text-2'>Kaler Kantho</b:widget-setting>
                        <b:widget-setting name='link-2'>https://www.kalerkantho.com/</b:widget-setting>
                        <b:widget-setting name='text-3'>Jugantor</b:widget-setting>
                        <b:widget-setting name='link-3'>https://www.jugantor.com/</b:widget-setting>
