        </div>
    </div>

    <!-- News Viewer Modal -->
    <div id='newsViewer'>
        <div class='viewer-header'>
            <span id='viewerTitle'>Loading...</span>
            <span class='close-btn' onclick='closeNews()'>&amp;times;</span>
        </div>
        <iframe id='newsFrame' src=''/>
    </div>

    <script type='text/javascript'>
        function viewNews(url, title) {
            document.getElementById('newsViewer').style.display = 'block';
            document.getElementById('newsFrame').src = url;
            document.getElementById('viewerTitle').innerText = title;
            document.body.style.overflow = 'hidden'; // Stop scrolling
        }
        function closeNews() {
            document.getElementById('newsViewer').style.display = 'none';
            document.getElementById('newsFrame').src = '';
            document.body.style.overflow = 'auto';
        }
    </script>
</body>
</html>
