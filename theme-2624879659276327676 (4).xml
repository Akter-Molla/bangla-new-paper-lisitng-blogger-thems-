    <script type='text/javascript'>
    //<![CDATA[
    (function() {
        var modal = document.getElementById('fullscreenModal');
        var iframe = document.getElementById('fullscreenIframe');
        var modalSiteName = document.getElementById('modalSiteName');
        var modalFavicon = document.getElementById('modalFavicon');
        var currentUrl = '';

        function openFullscreenModal(url, siteName, logoUrl) {
            if (!url) return;
            currentUrl = url;
            modalSiteName.innerHTML = '<strong>' + siteName + '</strong>';
            if (logoUrl && logoUrl !== '') {
                modalFavicon.src = logoUrl;
                modalFavicon.style.display = 'block';
                modalFavicon.onerror = function() { modalFavicon.style.display = 'none'; };
            } else {
                modalFavicon.style.display = 'none';
            }
            iframe.src = url;
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            modal.classList.remove('active');
            iframe.src = 'about:blank';
            document.body.style.overflow = '';
        }

        function openExternalTab() {
            if (currentUrl) {
                window.open(currentUrl, '_blank', 'noopener,noreferrer');
            }
        }

        var closeBtn = document.getElementById('closeModalBtn');
        var externalBtn = document.getElementById('openExternalBtn');
        if (closeBtn) closeBtn.addEventListener('click', closeModal);
        if (externalBtn) externalBtn.addEventListener('click', openExternalTab);
        
        if (modal) {
            modal.addEventListener('click', function(e) {
                if (e.target === modal) closeModal();
            });
        }
        
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && modal && modal.classList.contains('active')) closeModal();
        });

        // Simple click delegation - no mutation observer to prevent hang
        document.body.addEventListener('click', function(e) {
            var card = e.target.closest('.news-card');
            if (card) {
                var url = card.getAttribute('data-url');
                var name = card.getAttribute('data-name');
                var logo = card.getAttribute('data-logo');
                if (url) {
                    e.preventDefault();
                    openFullscreenModal(url, name, logo);
                }
            }
        });
    })();
    //]]>
    </script>
</body>
</html>