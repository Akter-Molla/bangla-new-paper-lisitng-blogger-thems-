    <title><data:blog.pageTitle/></title>

    <link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;family=Hind+Siliguri:wght@400;500;600;700&amp;display=swap' rel='stylesheet'/>
    <link href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css' rel='stylesheet'/>

    <b:skin version='2'><![CDATA[
        :root {
            --primary: #e74c3c;
            --secondary: #0f172a;
            --bg-light: #f8fafc;
            --surface: #ffffff;
            --border: #e2e8f0;
            --text-dark: #1e293b;
            --text-muted: #64748b;
            --shadow-sm: 0 4px 6px -1px rgba(0,0,0,0.05);
            --shadow-md: 0 10px 15px -3px rgba(0,0,0,0.08);
            --shadow-lg: 0 20px 25px -5px rgba(0,0,0,0.1);
            --transition: all 0.25s ease;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg-light);
            font-family: 'Inter', 'Hind Siliguri', sans-serif;
            color: var(--text-dark);
            padding-top: 80px;
            line-height: 1.5;
        }

        .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }

        header {
            background: var(--surface);
            height: 80px;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            box-shadow: var(--shadow-sm);
        }

        .header-flex {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            flex-wrap: wrap;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo {
            font-size: 28px;
            font-weight: 800;
            text-decoration: none;
            background: linear-gradient(135deg, var(--secondary) 0%, #2d3a5e 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .logo span {
            background: linear-gradient(135deg, var(--primary) 0%, #ff6b5b 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .logo-icon { font-size: 32px; color: var(--primary); }

        .hero {
            background: linear-gradient(135deg, #0f172a 0%, #1e2a4a 100%);
            border-radius: 32px;
            padding: 50px 30px;
            margin: 30px 0 40px;
            color: white;
            text-align: center;
            box-shadow: var(--shadow-lg);
        }
        .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 12px; }
        .hero p { font-size: 1.1rem; opacity: 0.9; max-width: 700px; margin: 0 auto; }
        .hero-badge {
            display: inline-block;
            background: rgba(255,255,255,0.15);
            border-radius: 40px;
            padding: 6px 18px;
            font-size: 0.8rem;
            margin-bottom: 20px;
        }

        .main-wrapper {
            display: flex;
            flex-wrap: wrap;
            gap: 32px;
            margin-bottom: 60px;
        }
        .main-content { flex: 2.5; min-width: 0; }
        .sidebar-right { flex: 1; min-width: 280px; }

        .category-section { margin-bottom: 48px; }
        .cat-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
            border-left: 5px solid var(--primary);
            padding-left: 18px;
        }
        .cat-header h2 { font-size: 1.6rem; font-weight: 700; color: var(--secondary); }
        .cat-header i { color: var(--primary); font-size: 1.4rem; }

        .news-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 20px;
        }

        .news-card {
            background: var(--surface);
            border-radius: 20px;
            padding: 18px 14px;
            text-align: center;
            border: 1px solid var(--border);
            transition: var(--transition);
            cursor: pointer;
            box-shadow: var(--shadow-sm);
        }
        .news-card:hover {
            transform: translateY(-6px);
            border-color: var(--primary);
            box-shadow: var(--shadow-md);
        }
        .news-card img {
            width: 55px;
            height: 55px;
            border-radius: 16px;
            margin-bottom: 12px;
            background: #fff;
            padding: 5px;
            object-fit: contain;
        }
        .news-card span { display: block; font-weight: 700; font-size: 0.95rem; color: var(--text-dark); }
        .news-card small { font-size: 0.75rem; color: var(--text-muted); margin-top: 6px; display: block; }

        .news-desc {
            margin-top: 8px;
            font-size: 0.78rem;
            color: var(--text-muted);
            min-height: 32px;
        }

        .sidebar-widget {
            background: var(--surface);
            border-radius: 24px;
            border: 1px solid var(--border);
            padding: 20px;
            margin-bottom: 30px;
            box-shadow: var(--shadow-sm);
        }
        .sidebar-widget-title {
            font-size: 1.2rem;
            font-weight: 700;
            border-bottom: 3px solid var(--primary);
            display: inline-block;
            padding-bottom: 6px;
            margin-bottom: 18px;
            color: var(--secondary);
        }
        .sidebar-list { list-style: none; }
        .sidebar-list li {
            margin-bottom: 12px;
            border-left: 2px solid var(--border);
            padding-left: 12px;
        }
        .sidebar-list a {
            text-decoration: none;
            color: var(--text-dark);
            font-weight: 500;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
        }
        .sidebar-list a:hover { color: var(--primary); transform: translateX(3px); }
        .sidebar-list i { width: 24px; color: var(--primary); }

        .modal-view {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.95);
            z-index: 9999;
            display: none;
            flex-direction: column;
        }
        .modal-bar {
            background: #1e293b;
            padding: 14px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: #fff;
            flex-wrap: wrap;
            gap: 10px;
        }
        .modal-bar .site-info {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .open-new-tab-btn {
            background: #2d3748;
            border: 1px solid #4a5568;
            color: #fff;
            padding: 6px 14px;
            border-radius: 40px;
            cursor: pointer;
            font-size: 0.8rem;
            transition: 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .open-new-tab-btn:hover {
            background: var(--primary);
            border-color: var(--primary);
        }
        iframe#readerFrame {
            flex: 1;
            border: none;
            background: #fff;
            width: 100%;
        }
        .close-btn {
            background: var(--primary);
            border: none;
            color: #fff;
            padding: 8px 20px;
            border-radius: 40px;
            cursor: pointer;
            font-weight: 600;
        }
        .error-message {
            display: none;
            text-align: center;
            padding: 80px 20px;
            background: #f8fafc;
            height: 100%;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .error-message i { font-size: 64px; color: var(--primary); margin-bottom: 20px; }
        .error-message h3 { margin-bottom: 15px; color: var(--secondary); }
        .error-message p { margin-bottom: 20px; color: var(--text-muted); max-width: 400px; }

        footer {
            background: var(--secondary);
            color: #cbd5e1;
            padding: 48px 0 24px;
            margin-top: 40px;
        }
        .footer-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 40px;
            justify-content: space-between;
            margin-bottom: 40px;
        }
        .footer-col { flex: 1; min-width: 180px; }
        .footer-logo { font-size: 24px; font-weight: 800; color: white; margin-bottom: 12px; display: inline-block; }
        .footer-logo span { color: var(--primary); }
        .footer-title { color: white; font-weight: 700; margin-bottom: 18px; border-left: 3px solid var(--primary); padding-left: 12px; }
        .footer-links { list-style: none; }
        .footer-links li { margin-bottom: 10px; }
        .footer-links a { color: #cbd5e1; text-decoration: none; transition: var(--transition); font-size: 0.9rem; }
        .footer-links a:hover { color: var(--primary); padding-left: 5px; }
        .copyright { text-align: center; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1); font-size: 0.8rem; }

        @media (max-width: 800px) {
            body { padding-top: 110px; }
            .hero h1 { font-size: 1.8rem; }
            .main-wrapper { flex-direction: column; }
            .news-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
            header { height: auto; }
        }
    ]]></b:skin>
</head>

