    <div class='modal-overlay' id='newsModal'>
        <div class='modal-content'>
            <div class='modal-header'>
                <span id='modalTitle' style='font-weight:700; font-family:Hind Siliguri;'>Loading...</span>
                <button class='close-btn' onclick='closeNews()'>বন&#2509;ধ কর&#2497;ন (Close)</button>
