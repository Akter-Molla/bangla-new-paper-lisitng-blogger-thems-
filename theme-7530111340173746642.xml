<div id='iframeError' style='display:none; padding:30px; text-align:center; color:#fff;'>
    <i class='fas fa-exclamation-triangle' style='font-size:44px; color:#f59e0b;'/>
    <h3 style='margin-top:12px;'>এই স&#2494;ইটট&#2495; frame-এ খ&#2507;ল&#2494; য&#2494;চ&#2509;ছ&#2503; ন&#2494;</h3>
    <p style='margin:10px 0 18px;'>স&#2494;ইটট&#2495; ন&#2495;র&#2494;পত&#2509;ত&#2494;র ক&#2494;রণ&#2503; iframe block কর&#2503;ছ&#2503;&#2404; নত&#2497;ন ট&#2509;য&#2494;ব&#2503; খ&#2507;ল&#2494; হচ&#2509;ছ&#2503;&#2404;</p>
    <a class='open-new-tab-btn' href='#' id='errorOpenLink' target='_blank'>
        <i class='fas fa-external-link-alt'/> নত&#2497;ন ট&#2509;য&#2494;ব&#2503; খ&#2497;ল&#2497;ন
    </a>
</div>
  <div id='viewer'/>
<script>
function loadSite(url) {
  fetch(&#39;/proxy.php?url=&#39; + encodeURIComponent(url))
    .then(r =&gt; r.text())
    .then(html =&gt; {
      document.getElementById(&#39;viewer&#39;).innerHTML = html;
    })
    .catch(() =&gt; {
      window.open(url, &#39;_blank&#39;);
    });
}
</script>
<script type='text/javascript'>
var loadTimer = null;
var currentUrl = &#39;&#39;;
var blockedHosts = [
    &#39;ntvbd.com&#39;,
    &#39;www.ntvbd.com&#39;,
    &#39;facebook.com&#39;,
    &#39;www.facebook.com&#39;
];

function isBlockedSite(url) {
    try {
        var host = new URL(url).hostname.replace(/^www\./, &#39;&#39;);
        return blockedHosts.indexOf(host) !== -1;
    } catch (e) {
        return false;
    }
}

function viewNews(url, title) {
    currentUrl = url;

    document.getElementById(&#39;newsViewer&#39;).style.display = &#39;block&#39;;
    document.getElementById(&#39;viewerTitle&#39;).innerText = title || &#39;News&#39;;
    document.body.style.overflow = &#39;hidden&#39;;

    var frame = document.getElementById(&#39;newsFrame&#39;);
    var errorBox = document.getElementById(&#39;iframeError&#39;);
    var openLink = document.getElementById(&#39;errorOpenLink&#39;);

    if (openLink) openLink.href = url;
    if (errorBox) errorBox.style.display = &#39;none&#39;;

    if (isBlockedSite(url)) {
        if (frame) frame.style.display = &#39;none&#39;;
        if (errorBox) errorBox.style.display = &#39;block&#39;;
        window.open(url, &#39;_blank&#39;);
        return;
    }

    if (frame) {
        frame.style.display = &#39;block&#39;;
        frame.src = &#39;about:blank&#39;;
        setTimeout(function () {
            frame.src = url;
        }, 50);
    }

    if (loadTimer) clearTimeout(loadTimer);
    loadTimer = setTimeout(function () {
        showIframeError();
    }, 5000);
}

function showIframeError() {
    var frame = document.getElementById(&#39;newsFrame&#39;);
    var errorBox = document.getElementById(&#39;iframeError&#39;);
    var openLink = document.getElementById(&#39;errorOpenLink&#39;);

    if (frame) frame.style.display = &#39;none&#39;;
    if (errorBox) errorBox.style.display = &#39;block&#39;;
    if (openLink &amp;&amp; currentUrl) openLink.href = currentUrl;
}

function closeNews() {
    if (loadTimer) clearTimeout(loadTimer);

    document.getElementById(&#39;newsViewer&#39;).style.display = &#39;none&#39;;
    document.getElementById(&#39;newsFrame&#39;).src = &#39;&#39;;
    document.getElementById(&#39;newsFrame&#39;).style.display = &#39;block&#39;;

    var errorBox = document.getElementById(&#39;iframeError&#39;);
    if (errorBox) errorBox.style.display = &#39;none&#39;;

    document.body.style.overflow = &#39;auto&#39;;
}
</script>
</body>
</html>