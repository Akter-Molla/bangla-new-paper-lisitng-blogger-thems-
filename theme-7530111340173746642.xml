    <b:skin><![CDATA[
        /* --- CSS Reset & Variables --- */
        :root {
            --primary-color: #007bff;
            --bg-color: #f4f7f6;
            --text-color: #333;
            --card-bg: #ffffff;
            --header-bg: #1a237e;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 0;
        }
        /* --- Layout --- */
        .main-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        .cat-header {
            display: flex;
            align-items: center;
            background: var(--header-bg);
            color: white;
            padding: 10px 20px;
            border-radius: 8px 8px 0 0;
            margin-top: 30px;
        }
        .cat-header i { margin-right: 15px; font-size: 1.5rem; }
        .cat-header h2 { margin: 0; font-size: 1.2rem; font-weight: 500; }

        .news-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 15px;
            background: #fff;
            padding: 20px;
            border-radius: 0 0 8px 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }
        .news-card {
            background: var(--card-bg);
            border: 1px solid #eee;
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .news-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        .news-card img {
            width: 48px;
            height: 48px;
            margin-bottom: 10px;
            border-radius: 50%;
            background: #f9f9f9;
        }
        .news-card span {
            display: block;
            font-weight: bold;
            font-size: 14px;
            margin-bottom: 5px;
        }
        .news-card small {
            color: #777;
            font-size: 11px;
        }

        /* --- News Viewer (Modal) --- */
        #newsViewer {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: white;
            z-index: 9999;
        }
        .viewer-header {
            height: 50px;
            background: #333;
            color: white;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
        }
        #newsFrame {
            width: 100%;
            height: calc(100% - 50px);
            border: none;
        }
        .close-btn { cursor: pointer; font-size: 24px; }
    ]]></b:skin>
